# Copy to .env.local and fill in real values. Do NOT commit .env.local — it is gitignored.

# Required — the server refuses to start without these.
DATABASE_URL=postgresql://user:password@host:port/dbname
JWT_SECRET=replace_with_32_byte_hex_from_crypto_randomBytes
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Optional — reserved for future use.
GEMINI_API_KEY=

# Optional — Railway sets NODE_ENV=production automatically on deploy.
# NODE_ENV=development
